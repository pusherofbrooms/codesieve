{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Basic CloudFormation fixture",
  "Parameters": {
    "EnvName": {
      "Type": "String"
    }
  },
  "Resources": {
    "AppBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "${EnvName}-app-bucket"
        }
      }
    }
  },
  "Outputs": {
    "BucketName": {
      "Value": {
        "Ref": "AppBucket"
      }
    }
  }
}
