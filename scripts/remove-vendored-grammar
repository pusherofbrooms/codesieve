#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "usage: $0 <python|javascript|typescript>" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
cd "$repo_root"

case "$1" in
  python)
    target="third_party/tree-sitter-python"
    ;;
  javascript)
    target="third_party/tree-sitter-javascript"
    ;;
  typescript)
    target="third_party/tree-sitter-typescript"
    ;;
  *)
    echo "unknown grammar: $1" >&2
    echo "expected one of: python, javascript, typescript" >&2
    exit 1
    ;;
esac

echo "Removing vendored grammar tree: $repo_root/$target"
rm -rf "$target"
