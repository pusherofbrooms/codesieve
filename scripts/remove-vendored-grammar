#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=scripts/language-map.sh
source "$script_dir/language-map.sh"

if [ "$#" -ne 1 ]; then
  echo "usage: $0 <$(IFS='|'; echo "${codesieve_treesitter_languages[*]}")>" >&2
  exit 1
fi

repo_root="$(cd "$script_dir/.." && pwd)"
cd "$repo_root"

if ! target="$(codesieve_grammar_dir_for_language "$1")"; then
  echo "unknown grammar: $1" >&2
  echo "expected one of: $(IFS=', '; echo "${codesieve_treesitter_languages[*]}")" >&2
  exit 1
fi

echo "Removing vendored grammar tree: $repo_root/$target"
rm -rf "$target"
