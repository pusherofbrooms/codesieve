#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=scripts/language-map.sh
source "$script_dir/language-map.sh"

usage() {
  cat >&2 <<EOF
usage: scripts/vendor-grammar <language> <tag-or-sha> [--repo=<git-url>] [--dest=<path>]

Known languages:
$(for lang in "${codesieve_treesitter_languages[@]}"; do
  repo="$(codesieve_grammar_repo_for_language "$lang")"
  printf '  %-11s -> %s\n' "$lang" "$repo"
done)
Examples:
  scripts/vendor-grammar bash v0.25.1
  scripts/vendor-grammar python v0.23.6
  scripts/vendor-grammar javascript master --dest=third_party/tree-sitter-javascript
  scripts/vendor-grammar custom abc123 --repo=https://github.com/org/tree-sitter-custom.git
EOF
}

repo_for_language() {
  codesieve_grammar_repo_for_language "$1"
}

if [ "$#" -eq 1 ] && { [ "$1" = "--help" ] || [ "$1" = "-h" ] || [ "$1" = "help" ]; }; then
  usage
  exit 0
fi

if [ "$#" -lt 2 ]; then
  usage
  exit 1
fi

if ! command -v git >/dev/null 2>&1; then
  echo "error: git is required" >&2
  exit 1
fi

language="$1"
ref="$2"
shift 2

repo_root="$(cd "$script_dir/.." && pwd)"
cd "$repo_root"

repo_url=""
dest="third_party/tree-sitter-$language"

for arg in "$@"; do
  case "$arg" in
    --repo=*)
      repo_url="${arg#--repo=}"
      ;;
    --dest=*)
      dest="${arg#--dest=}"
      ;;
    --help|-h|help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown flag: $arg" >&2
      usage
      exit 1
      ;;
  esac
done

if [ -z "$repo_url" ]; then
  if ! repo_url="$(repo_for_language "$language")"; then
    echo "error: unknown language '$language' (use --repo=... for custom grammars)" >&2
    exit 1
  fi
fi

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

checkout_dir="$tmp_dir/grammar"

echo "Cloning grammar repo..."
git clone "$repo_url" "$checkout_dir" >/dev/null 2>&1

echo "Checking out $ref..."
if ! git -C "$checkout_dir" checkout "$ref" >/dev/null 2>&1; then
  echo "error: failed to checkout ref '$ref' from $repo_url" >&2
  exit 1
fi

commit="$(git -C "$checkout_dir" rev-parse HEAD)"

required=(
  "tree-sitter.json"
  "LICENSE"
)
for rel in "${required[@]}"; do
  if [ ! -f "$checkout_dir/$rel" ]; then
    echo "error: missing required file in grammar checkout: $rel" >&2
    exit 1
  fi
done

has_parser=0
if [ -f "$checkout_dir/src/parser.c" ]; then
  has_parser=1
elif command -v jq >/dev/null 2>&1; then
  while IFS= read -r grammar_path; do
    if [ -n "$grammar_path" ] && [ -f "$checkout_dir/$grammar_path/src/parser.c" ]; then
      has_parser=1
      break
    fi
  done < <(jq -r '.grammars[]?.path // empty' "$checkout_dir/tree-sitter.json")
fi

if [ "$has_parser" -ne 1 ]; then
  echo "error: missing required parser.c (expected src/parser.c or <grammar-path>/src/parser.c)" >&2
  exit 1
fi

# scanner.c is optional for some grammars.

echo "Vendoring into $dest"
rm -rf "$dest"
mkdir -p "$dest"
cp -a "$checkout_dir"/. "$dest"/
rm -rf "$dest/.git"

cat >"$dest/.codesieve-vendor-meta" <<EOF
repository=$repo_url
requested_ref=$ref
resolved_commit=$commit
vendored_at_utc=$(date -u +%Y-%m-%dT%H:%M:%SZ)
script=scripts/vendor-grammar
EOF

if [ -x "scripts/prune-vendored-grammars" ] && [[ "$dest" == third_party/tree-sitter-* ]] && codesieve_is_known_treesitter_language "$language"; then
  scripts/prune-vendored-grammars "$language"
fi

echo "Done."
echo "- language: $language"
echo "- destination: $dest"
echo "- repository: $repo_url"
echo "- commit: $commit"
