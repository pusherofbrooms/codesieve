#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=scripts/language-map.sh
source "$script_dir/language-map.sh"

usage() {
  cat >&2 <<EOF
usage: scripts/prune-vendored-grammars [all|<language>]

Known languages: $(IFS=', '; echo "${codesieve_treesitter_languages[*]}")

Prunes vendored grammar trees down to the files needed by codesieve builds:
- grammar C sources under src/
- tree-sitter.json
- LICENSE* at grammar root
- .codesieve-vendor-meta

TypeScript additionally keeps:
- common/scanner.h
- typescript/src/
- tsx/src/
EOF
}

repo_root="$(cd "$script_dir/.." && pwd)"
cd "$repo_root"

if [ "$#" -ne 1 ]; then
  usage
  exit 1
fi

arg="$1"

if [ "$arg" = "all" ]; then
  targets=("${codesieve_treesitter_languages[@]}")
else
  targets=("$arg")
fi

copy_if_exists() {
  local src="$1"
  local dst="$2"
  if [ -e "$src" ]; then
    mkdir -p "$(dirname "$dst")"
    cp -a "$src" "$dst"
  fi
}

for lang in "${targets[@]}"; do
  if ! codesieve_is_known_treesitter_language "$lang"; then
    echo "error: unknown grammar '$lang'" >&2
    usage
    exit 1
  fi

  dir="third_party/tree-sitter-$lang"
  if [ ! -d "$dir" ]; then
    echo "skip: $dir does not exist"
    continue
  fi

  tmp="$(mktemp -d)"
  newdir="$tmp/tree"
  mkdir -p "$newdir"

  copy_if_exists "$dir/.codesieve-vendor-meta" "$newdir/.codesieve-vendor-meta"
  copy_if_exists "$dir/tree-sitter.json" "$newdir/tree-sitter.json"
  copy_if_exists "$dir/src" "$newdir/src"

  shopt -s nullglob
  for lf in "$dir"/LICENSE*; do
    copy_if_exists "$lf" "$newdir/$(basename "$lf")"
  done
  shopt -u nullglob

  if [ "$lang" = "typescript" ]; then
    copy_if_exists "$dir/common/scanner.h" "$newdir/common/scanner.h"
    copy_if_exists "$dir/typescript/src" "$newdir/typescript/src"
    copy_if_exists "$dir/tsx/src" "$newdir/tsx/src"
  fi

  rm -rf "$dir"
  mkdir -p "$(dirname "$dir")"
  mv "$newdir" "$dir"
  rm -rf "$tmp"

  echo "pruned: $dir"
done
